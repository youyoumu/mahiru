{
  "name": "mahiru",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "quality": "turbo run quality",
    "quality:fix": "turbo run quality:fix",
    "migrate": "pnpm -F @repo/db run migrate",
    "generate": "pnpm -F @repo/db run generate",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "docker-build:backend": "docker build -t youyoumu2025/mahiru-backend:latest -f apps/backend/Dockerfile .",
    "docker-build:backend:debug": "docker build -t youyoumu2025/mahiru-backend:latest -f apps/backend/Dockerfile . --build-arg DEBUG_TOOLS=true",
    "docker-interactive:backend": "docker run --env-file ./apps/backend/.env -it youyoumu2025/mahiru-backend:latest sh",
    "docker-push:backend": "docker push youyoumu2025/mahiru-backend:latest",
    "docker-build:bot": "docker build -t youyoumu2025/mahiru-bot:latest -f apps/bot/Dockerfile .",
    "docker-build:bot:debug": "docker build -t youyoumu2025/mahiru-bot:latest -f apps/bot/Dockerfile . --build-arg DEBUG_TOOLS=true",
    "docker-interactive:bot": "docker run --env-file ./apps/bot/.env -it youyoumu2025/mahiru-bot:latest sh",
    "docker-push:bot": "docker push youyoumu2025/mahiru-bot:latest"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.6",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0"
}
